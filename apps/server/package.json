{
  "name": "server",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "build": "tsdown",
    "check-types": "tsc -b",
    "compile": "bun build --compile --minify --sourcemap --bytecode ./src/index.ts --outfile server",
    "dev": "bun run --hot src/index.ts",
    "start": "bun run dist/index.mjs"
  },
  "dependencies": {
    "@meteor/auth": "workspace:*",
    "@meteor/db": "workspace:*",
    "better-auth": "1.6.11",
    "dotenv": "^17.4.2",
    "evlog": "^2.15.0",
    "hono": "^4.12.16",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@meteor/config": "workspace:*",
    "@types/bun": "^1.3.13",
    "tsdown": "^0.21.10",
    "typescript": "^6.0.3"
  }
}
