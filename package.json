{
  "name": "meteor",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ],
    "catalog": {
      "dotenv": "^17.3.1",
      "zod": "^4.3.6",
      "@types/bun": "^1.3.11",
      "better-auth": "1.5.5",
      "lucide-react": "^0.577.0",
      "next-themes": "^0.4.6",
      "react": "^19.2.4",
      "react-dom": "^19.2.4",
      "sonner": "^2.0.7",
      "@prisma/client": "^7.5.0",
      "@types/react": "^19.2.14",
      "@types/react-dom": "^19.2.3",
      "tailwindcss": "^4.2.2"
    }
  },
  "type": "module",
  "scripts": {
    "dev": "bun run --filter '*' dev",
    "build": "bun run --filter '*' build",
    "check-types": "bun run --filter '*' check-types",
    "deps:update": "bun .github/scripts/deps/update-deps.ts",
    "dev:web": "bun run --filter web dev",
    "dev:server": "bun run --filter server dev",
    "db:push": "bun run --filter @meteor/db db:push",
    "db:studio": "bun run --filter @meteor/db db:studio",
    "db:generate": "bun run --filter @meteor/db db:generate",
    "db:migrate": "bun run --filter @meteor/db db:migrate",
    "db:start": "bun run --filter @meteor/db db:start",
    "db:watch": "bun run --filter @meteor/db db:watch",
    "db:stop": "bun run --filter @meteor/db db:stop",
    "db:down": "bun run --filter @meteor/db db:down",
    "check": "biome check --write ."
  },
  "dependencies": {
    "@meteor/env": "workspace:*",
    "dotenv": "^17.3.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.8",
    "@meteor/config": "workspace:*",
    "@types/bun": "^1.3.11",
    "lefthook": "^2.1.4",
    "typescript": "^5.9.3"
  },
  "packageManager": "bun@1.3.11"
}
