{
  "name": "meteor",
  "private": true,
  "workspaces": {
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "type": "module",
  "scripts": {
    "dev": "turbo dev",
    "build": "turbo build",
    "check-types": "turbo check-types",
    "dev:web": "turbo -F web dev",
    "dev:server": "turbo -F server dev",
    "db:push": "turbo -F @meteor/db db:push",
    "db:studio": "turbo -F @meteor/db db:studio",
    "db:generate": "turbo -F @meteor/db db:generate",
    "db:migrate": "turbo -F @meteor/db db:migrate",
    "db:start": "turbo -F @meteor/db db:start",
    "db:watch": "turbo -F @meteor/db db:watch",
    "db:stop": "turbo -F @meteor/db db:stop",
    "db:down": "turbo -F @meteor/db db:down",
    "check": "biome check --write .",
    "check:ci": "biome check ."
  },
  "dependencies": {
    "dotenv": "^17.4.2",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.14",
    "@meteor/config": "workspace:*",
    "@types/bun": "^1.3.13",
    "turbo": "^2.9.9",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
